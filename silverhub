RunService.RenderStepped:Connect(function(dt)
    if not cfg then return end

    currentTarget = getBestTarget()

    if targetLabelRef then
        if currentTarget then
            targetLabelRef.Text       = ">> " .. currentTarget.Name
            targetLabelRef.TextColor3 = Color3.fromRGB(100,245,120)
        else
            local maps   = workspace:FindFirstChild("Maps")
            local noMap  = cfg.targetType == "pandi" and maps and #maps:GetChildren() == 0
            targetLabelRef.Text       = noMap and "select a map" or "no target"
            targetLabelRef.TextColor3 = T.textDim
        end
    end

    updateFOVCircle()

    if S.Enabled and (not S.RequireTool or isToolEquipped()) then
        local target = currentTarget
        if target then
            local pos = getAimPosition(target)
            if pos then
                local cf    = camera.CFrame
                local goal  = CFrame.lookAt(cf.Position, pos)
                local alpha = 1 - (1 - math.clamp(S.AimbotStrength,0,1)) ^ (dt * 60)
                camera.CFrame = cf:Lerp(goal, alpha)
            end
        end
    end

    if currentTarget then tryTriggerbot(currentTarget) end
end)
