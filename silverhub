                farmThread = task.spawn(function()
                    while farmActive do
                        local char = player.Character
                        local hrp  = char and char:FindFirstChild("HumanoidRootPart")
                        if hrp then hrp.CFrame = CFrame.new(cfg.farmTarget) end
                        task.wait(cfg.farmDelay)
                        farmLoops = farmLoops + 1
                        pcall(function() loopCountLabel:Set("Loops: " .. tostring(farmLoops)) end)
                    end
                end)
            else
                if farmThread then task.cancel(farmThread); farmThread = nil end
            end
        end,
    })

    FarmTab:Section({ name = "Point Calculator  (~" .. cfg.pointsPerLoop/1000 .. "k / loop)" })

    local calcTarget   = 0
    local loopsNeededL = FarmTab:Label({ text = "Loops needed:  —" })
    local estTimeL     = FarmTab:Label({ text = "Est. time:  —" })
    local progressL    = FarmTab:Label({ text = "Progress:  —" })

    local function recalculate()
        if calcTarget <= 0 then
            pcall(function() loopsNeededL:Set("Loops needed:  —") end)
            pcall(function() estTimeL:Set("Est. time:  —") end)
            pcall(function() progressL:Set("Progress:  —") end)
            return
        end
        local cur         = getCurrentPoints()
        local stillNeeded = math.max(0, calcTarget - cur)
        local needed      = math.ceil(stillNeeded / cfg.pointsPerLoop)
        local totalSec    = needed * cfg.farmDelay
        pcall(function()
            loopsNeededL:Set(string.format("Loops needed:  %d  (%d pts left)", needed, stillNeeded))
        end)
        if needed == 0 then
            pcall(function() estTimeL:Set("Est. time:  done! ✓") end)
            pcall(function() progressL:Set("Progress:  ✓ Target reached!") end)
        else
            local loopsTotal = math.ceil(calcTarget / cfg.pointsPerLoop)
            local loopsDone  = math.max(0, loopsTotal - needed)
            local pct        = math.min(100, math.floor((loopsDone/loopsTotal)*100))
            pcall(function() estTimeL:Set("Est. time:  " .. formatTime(totalSec)) end)
            pcall(function()
                progressL:Set(string.format("Progress:  %d/%d  (%d%%)  ~%s left",
                    loopsDone, loopsTotal, pct, formatTime(totalSec)))
            end)
        end
    end

    FarmTab:Slider({
        name     = "Target Points (x25k)",
        min      = 1, max = 4000, default = 20,
        suffix   = "  =  500k",
        callback = function(v)
            calcTarget = v * 25000
            recalculate()
        end,
    })

    task.spawn(function()
        while true do
            task.wait(cfg.farmDelay)
            if calcTarget > 0 then recalculate() end
        end
    end)
end

