-- ─────────────────────────────────────────────────────────

local fovCircle

local function ensureFOVCircle()
    if fovCircle then return end
    fovCircle = Drawing.new("Circle")
    fovCircle.Thickness = 1; fovCircle.Filled = false
    fovCircle.NumSides  = 64; fovCircle.Transparency = 0.6
end

local function updateFOVCircle()
    ensureFOVCircle()
    if not S.ShowFOVCircle then fovCircle.Visible = false return end
    local vp  = camera.ViewportSize
    local rad = (math.tan(math.rad(S.FOV)) /
                 math.tan(math.rad(camera.FieldOfView * 0.5))) * (vp.Y * 0.5)
    fovCircle.Position     = Vector2.new(vp.X * 0.5, vp.Y * 0.5)
    fovCircle.Radius       = rad; fovCircle.Visible = true
    fovCircle.Color        = currentTarget and Color3.fromRGB(100,245,120) or Color3.fromRGB(200,200,220)
    fovCircle.Transparency = currentTarget and 0.25 or 0.6
end

-- ─────────────────────────────────────────────────────────
--  FIX 2 — ESP
--  Uses Roblox Highlight (no Drawing needed).
--  Managed outside RenderStepped via PlayerAdded + CharacterAdded.
--  Re-attaches automatically on respawn.
-- ─────────────────────────────────────────────────────────

local ESP_ENABLED = false
local espObjects  = {}  -- [player] = Highlight instance

local function removeESP(p)
    if espObjects[p] then
        espObjects[p]:Destroy()
        espObjects[p] = nil
    end
end

local function attachESP(p)
    removeESP(p)
    local char = p.Character
    if not char then return end
    local h = Instance.new("Highlight")
    h.FillColor          = Color3.fromRGB(255, 60, 60)
    h.OutlineColor       = Color3.fromRGB(255, 255, 255)
    h.FillTransparency   = 0.5
    h.OutlineTransparency = 0
    h.DepthMode          = Enum.HighlightDepthMode.AlwaysOnTop
    h.Adornee            = char
    h.Parent             = char
    espObjects[p]        = h
end

local function clearAllESP()
    for p in pairs(espObjects) do removeESP(p) end
end

-- Wire up all existing players
for _, p in ipairs(Players:GetPlayers()) do
    if p == player then continue end
    -- attach now if ESP already on (re-exec case)
    p.CharacterAdded:Connect(function()
        task.wait(0.1)
        if ESP_ENABLED then attachESP(p) end
    end)
    p.CharacterRemoving:Connect(function()
        removeESP(p)
    end)
end

-- Wire up future players
Players.PlayerAdded:Connect(function(p)
    if p == player then return end
    p.CharacterAdded:Connect(function()
        task.wait(0.1)
        if ESP_ENABLED then attachESP(p) end
    end)
    p.CharacterRemoving:Connect(function()
        removeESP(p)
    end)
end)

Players.PlayerRemoving:Connect(function(p)
    removeESP(p)
end)

local function setESP(enabled)
    ESP_ENABLED = enabled
    if enabled then
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= player then attachESP(p) end
        end
    else
        clearAllESP()
    end
end

