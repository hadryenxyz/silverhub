UserInputService.InputBegan:Connect(function(input, gpe)
    -- Keybind rebinding (no gpe check, we want to capture anything)
    if listeningFor then
        if input.KeyCode ~= Enum.KeyCode.Unknown then
            S[listeningFor] = input.KeyCode
            listeningFor = nil
            -- Update button text across the UI
            for _, obj in ipairs(player.PlayerGui.SilverHubV2.Window:GetDescendants()) do
                if obj:IsA("TextButton") and obj:GetAttribute("SettingKey") == listeningFor then
                    -- already nil, so use the stored key directly
                end
            end
            -- Just refresh the two known buttons
            if aimKeyBtn then
                aimKeyBtn.Text = tostring(S.KB_AIM):gsub("Enum.KeyCode.","")
                aimKeyBtn.TextColor3 = T.accent
                local ks2 = aimKeyBtn:FindFirstChildOfClass("UIStroke")
                if ks2 then TweenService:Create(ks2,TweenInfo.new(0.1),{Color=T.border}):Play() end
            end
            if guiKeyBtn then
                guiKeyBtn.Text = tostring(S.KB_GUI):gsub("Enum.KeyCode.","")
                guiKeyBtn.TextColor3 = T.accent
                local ks2 = guiKeyBtn:FindFirstChildOfClass("UIStroke")
                if ks2 then TweenService:Create(ks2,TweenInfo.new(0.1),{Color=T.border}):Play() end
            end
        end
        return  -- swallow input while listening
    end

    if gpe then return end
    if input.KeyCode == S.KB_AIM then
        S.Enabled = not S.Enabled
    elseif input.KeyCode == S.KB_GUI then
        if mainGui then mainGui.Enabled = not mainGui.Enabled end
    end
end)

