local function isToolEquipped()
    local char = player.Character
    return char and char:FindFirstChildOfClass("Tool") ~= nil
end

local function getAimPart(obj)
    if obj:IsA("BasePart") then return obj end
    if obj.PrimaryPart     then return obj.PrimaryPart end
    local hrp = obj:FindFirstChild("HumanoidRootPart")
    if hrp then return hrp end
    return obj:FindFirstChildWhichIsA("BasePart")
end

local WALL_PARAMS = RaycastParams.new()
WALL_PARAMS.FilterType = Enum.RaycastFilterType.Exclude

local function isVisible(target)
    if not S.WallCheck then return true end
    local part = getAimPart(target)
    if not part then return true end
    local char = player.Character
    local ignore = char and {char} or {}
    table.insert(ignore, target:IsA("Model") and target or target.Parent)
    WALL_PARAMS.FilterDescendantsInstances = ignore
    local origin = camera.CFrame.Position
    local result = workspace:Raycast(origin, part.Position - origin, WALL_PARAMS)
    if not result then return true end
    local hit = result.Instance
    return hit:IsDescendantOf(target) or hit == target
end

-- Ping in seconds
local function getPing()
    local ok, str = pcall(function()
        return Stats.Network.ServerStatsItem["Data Ping"]:GetValueString()
    end)
    if not ok then return 0.05 end
    local ping = tonumber(string.match(str, "%d+"))
    return (ping or 50) / 1000
end

