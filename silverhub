local function fireShot()
    task.spawn(function()
        pcall(function() mouse1press(); task.wait(0.06); mouse1release() end)
    end)
end

local trigCooldown = false

local function tryTriggerbot(target)
    if not S.TrigEnabled or trigCooldown or not target then return end
    if S.RequireTool and not isToolEquipped() then return end
    local part = getAimPart(target)
    if not part then return end
    local dot   = math.clamp(camera.CFrame.LookVector:Dot(
        (part.Position - camera.CFrame.Position).Unit), -1, 1)
    if math.deg(math.acos(dot)) < S.TrigFOV then
        trigCooldown = true
        task.delay(0.04, function()
            fireShot()
            task.delay(0.18, function() trigCooldown = false end)
        end)
    end
end

