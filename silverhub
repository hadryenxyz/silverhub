local function isToolEquipped()
    local char = player.Character
    return char and char:FindFirstChildOfClass("Tool") ~= nil
end

local function getAimPart(obj)
    if obj:IsA("BasePart") then return obj end
    if obj.PrimaryPart     then return obj.PrimaryPart end
    local hrp = obj:FindFirstChild("HumanoidRootPart")
    if hrp then return hrp end
    return obj:FindFirstChildWhichIsA("BasePart")
end

local WALL_PARAMS = RaycastParams.new()
WALL_PARAMS.FilterType = Enum.RaycastFilterType.Exclude

local function isVisible(target)
    if not S.WallCheck then return true end
    local part = getAimPart(target)
    if not part then return true end
    local char   = player.Character
    local ignore = char and {char} or {}
    table.insert(ignore, target:IsA("Model") and target or target.Parent)
    WALL_PARAMS.FilterDescendantsInstances = ignore
    local origin = camera.CFrame.Position
    local result = workspace:Raycast(origin, part.Position - origin, WALL_PARAMS)
    if not result then return true end
    local hit = result.Instance
    if hit:IsDescendantOf(target) or hit == target then return true end
    return false
end

-- ─────────────────────────────────────────────────────────
--  TARGET ACQUISITION
-- ─────────────────────────────────────────────────────────

local _daHoodContainer
local currentTarget = nil

local function getTargetList()
    local list = {}
    local tt   = cfg.targetType

    if tt == "players" then
        for _, p in ipairs(Players:GetPlayers()) do
            if p == player then continue end
            local char = p.Character
            if not char then continue end
            local hrp = char:FindFirstChild("HumanoidRootPart")
            local hum = char:FindFirstChildOfClass("Humanoid")
            if hrp and hum and hum.Health > 0 then
                table.insert(list, char)
            end
        end

    elseif tt == "pandi" then
        local maps = workspace:FindFirstChild("Maps")
        if not maps then return list end
        for _, mapChild in ipairs(maps:GetChildren()) do
            local tf = mapChild:FindFirstChild("Targets")
            if not tf then continue end
            for _, obj in ipairs(tf:GetDescendants()) do
                if obj:IsA("Model") and getAimPart(obj) then table.insert(list, obj) end
            end
        end

    elseif tt == "workspaceTargetsParts" then
        local tf = workspace:FindFirstChild("Targets")
        if not tf then return list end
        for _, obj in ipairs(tf:GetChildren()) do
            if obj:IsA("BasePart") then table.insert(list, obj) end
        end

    elseif tt == "bots" then
        local folder = workspace:FindFirstChild("Bots")
        if not folder then return list end
        for _, bot in ipairs(folder:GetChildren()) do
            local hrp = bot:FindFirstChild("HumanoidRootPart")
            local hum = bot:FindFirstChildOfClass("Humanoid")
            if hrp and hum and hum.Health > 0 then table.insert(list, bot) end
        end

    elseif tt == "daHoodBots" then
        for _, child in ipairs(workspace:GetChildren()) do
            if child.Name == "DaTNTShow52" then
                local hrp = child:FindFirstChild("HumanoidRootPart")
                local hum = child:FindFirstChildOfClass("Humanoid")
                if hrp and hum and hum.Health > 0 then table.insert(list, child) end
            end
        end
        if #list == 0 then
            if not _daHoodContainer or not _daHoodContainer.Parent then
                _daHoodContainer = nil
                for _, child in ipairs(workspace:GetChildren()) do
                    if not child:IsA("Terrain") and not child:IsA("Camera") then
                        local first = child:GetChildren()[1]
                        if first and first:FindFirstChild("HumanoidRootPart") then
                            _daHoodContainer = child; break
                        end
                    end
                end
                if not _daHoodContainer then
                    _daHoodContainer = workspace:GetChildren()[9]
                end
            end
            if _daHoodContainer then
                for _, bot in ipairs(_daHoodContainer:GetChildren()) do
                    local hrp = bot:FindFirstChild("HumanoidRootPart")
                    local hum = bot:FindFirstChildOfClass("Humanoid")
                    if hrp and hum and hum.Health > 0 then table.insert(list, bot) end
                end
            end
        end
    end

    return list
end

local function getBestTarget()
    local best, bestAngle = nil, math.huge
    for _, obj in ipairs(getTargetList()) do
        local part = getAimPart(obj)
        if not part then continue end
        local dir   = part.Position - camera.CFrame.Position
        local dot   = math.clamp(camera.CFrame.LookVector:Dot(dir.Unit), -1, 1)
        local angle = math.deg(math.acos(dot))
        if angle < S.FOV and angle < bestAngle and isVisible(obj) then
            bestAngle = angle; best = obj
        end
    end
    return best
end

-- ─────────────────────────────────────────────────────────
--  AIM POSITION
-- ─────────────────────────────────────────────────────────

local function getAimPosition(target)
    local part = getAimPart(target)
    if not part then return nil end
    local basePos = part.Position
    if not cfg.prediction or not S.UsePrediction then return basePos end
    local vel        = part.AssemblyLinearVelocity
    local dist       = (basePos - camera.CFrame.Position).Magnitude
    local travelTime = dist / math.max(S.BulletSpeed, 1)
    local scaledVel  = Vector3.new(vel.X, vel.Y * 0.1, vel.Z)
    local predicted  = basePos + scaledVel * travelTime
    local horizVel   = Vector3.new(vel.X, 0, vel.Z)
    if horizVel.Magnitude > 0.5 and S.PredOffset > 0 then
        predicted = predicted + horizVel.Unit * S.PredOffset
    end
    return predicted
end

